{
  "$schema": "https://raw.githubusercontent.com/code-yeongyu/oh-my-opencode/dev/assets/oh-my-opencode.schema.json",
  "agents": {
    "sisyphus": {
      "model": "anthropic/claude-opus-4-7",
      "ultrawork": {
        "model": "anthropic/claude-opus-4-7",
        "variant": "xhigh"
      },
      "fallback_models": [
        {
          "model": "opencode-go/kimi-k2.5"
        },
        {
          "model": "github-copilot/gpt-5.4",
          "variant": "medium"
        }
      ]
    },
    "hephaestus": {
      "model": "github-copilot/gpt-5.4",
      "variant": "medium"
    },
    "oracle": {
      "model": "github-copilot/gpt-5.4",
      "variant": "high",
      "fallback_models": [
        {
          "model": "github-copilot/gemini-3.1-pro-preview",
          "variant": "high"
        },
        {
          "model": "anthropic/claude-opus-4-7"
        },
        {
          "model": "opencode-go/glm-5"
        }
      ]
    },
    "librarian": {
      "model": "opencode-go/minimax-m2.7"
    },
    "explore": {
      "model": "github-copilot/grok-code-fast-1",
      "fallback_models": [
        {
          "model": "opencode-go/minimax-m2.7"
        }
      ]
    },
    "multimodal-looker": {
      "model": "opencode-go/kimi-k2.5",
      "temperature": 1,
      "fallback_models": [
        {
          "model": "github-copilot/gpt-5-nano"
        }
      ]
    },
    "prometheus": {
      "model": "anthropic/claude-opus-4-7",
      "thinking": {
        "type": "enabled",
        "budgetTokens": 160000
      },
      "fallback_models": [
        {
          "model": "github-copilot/gpt-5.4",
          "variant": "high"
        },
        {
          "model": "opencode-go/glm-5"
        },
        {
          "model": "github-copilot/gemini-3.1-pro-preview"
        }
      ]
    },
    "metis": {
      "model": "anthropic/claude-opus-4-7",
      "fallback_models": [
        {
          "model": "github-copilot/gpt-5.4",
          "variant": "high"
        },
        {
          "model": "opencode-go/glm-5"
        }
      ]
    },
    "momus": {
      "model": "github-copilot/gpt-5.4",
      "variant": "xhigh",
      "fallback_models": [
        {
          "model": "anthropic/claude-opus-4-7"
        },
        {
          "model": "github-copilot/gemini-3.1-pro-preview",
          "variant": "high"
        },
        {
          "model": "opencode-go/glm-5"
        }
      ]
    },
    "atlas": {
      "model": "github-copilot/claude-sonnet-4.6",
      "fallback_models": [
        {
          "model": "opencode-go/kimi-k2.5"
        },
        {
          "model": "github-copilot/gpt-5.4",
          "variant": "medium"
        },
        {
          "model": "opencode-go/minimax-m2.7"
        }
      ]
    },
    "sisyphus-junior": {
      "model": "github-copilot/claude-sonnet-4.6",
      "fallback_models": [
        {
          "model": "opencode-go/kimi-k2.5"
        },
        {
          "model": "github-copilot/gpt-5.4",
          "variant": "medium"
        },
        {
          "model": "opencode-go/minimax-m2.7"
        }
      ]
    }
  },
  "categories": {
    "visual-engineering": {
      "model": "github-copilot/gemini-3.1-pro-preview",
      "variant": "high",
      "fallback_models": [
        {
          "model": "anthropic/claude-opus-4-7"
        },
        {
          "model": "opencode-go/glm-5"
        }
      ]
    },
    "ultrabrain": {
      "model": "github-copilot/gemini-3.1-pro-preview",
      "variant": "high",
      "fallback_models": [
        {
          "model": "anthropic/claude-opus-4-7"
        },
        {
          "model": "opencode-go/glm-5"
        }
      ]
    },
    "deep": {
      "model": "github-copilot/gpt-5.4",
      "variant": "medium",
      "fallback_models": [
        {
          "model": "anthropic/claude-opus-4-7"
        },
        {
          "model": "github-copilot/gemini-3.1-pro-preview",
          "variant": "high"
        }
      ]
    },
    "artistry": {
      "model": "github-copilot/gemini-3.1-pro-preview",
      "variant": "high",
      "fallback_models": [
        {
          "model": "anthropic/claude-opus-4-7"
        },
        {
          "model": "github-copilot/gpt-5.4"
        }
      ]
    },
    "quick": {
      "model": "github-copilot/gpt-5.4-mini",
      "fallback_models": [
        {
          "model": "github-copilot/claude-haiku-4.5"
        },
        {
          "model": "github-copilot/gemini-3-flash-preview"
        },
        {
          "model": "opencode-go/minimax-m2.7"
        }
      ]
    },
    "unspecified-low": {
      "model": "github-copilot/claude-sonnet-4.6",
      "fallback_models": [
        {
          "model": "opencode-go/kimi-k2.5"
        },
        {
          "model": "github-copilot/gemini-3-flash-preview"
        },
        {
          "model": "opencode-go/minimax-m2.7"
        }
      ]
    },
    "unspecified-high": {
      "model": "anthropic/claude-opus-4-7",
      "variant": "xhigh",
      "fallback_models": [
        {
          "model": "opencode-go/kimi-k2.5"
        },
        {
          "model": "github-copilot/gemini-3-flash-preview"
        },
        {
          "model": "opencode-go/minimax-m2.7"
        }
      ]
    },
    "writing": {
      "model": "github-copilot/gemini-3-flash-preview",
      "fallback_models": [
        {
          "model": "opencode-go/kimi-k2.5"
        },
        {
          "model": "github-copilot/claude-sonnet-4.6"
        },
        {
          "model": "opencode-go/minimax-m2.7"
        }
      ]
    }
  },
  "browser_automation_engine": {
    "provider": "dev-browser"
  },
  "runtime_fallback": {
    "enabled": true
  },
  "git_master": {
    "commit_footer": true,
    "include_co_authored_by": false,
    "git_env_prefix": "GIT_MASTER=1"
  },
  "tmux": {
    "enabled": true,
    "layout": "main-vertical",
    "main_pane_size": 60,
    "main_pane_min_width": 120,
    "agent_pane_min_width": 40,
    "isolation": "inline"
  }
}
