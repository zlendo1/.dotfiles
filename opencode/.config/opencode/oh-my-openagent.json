{
  "$schema": "https://raw.githubusercontent.com/code-yeongyu/oh-my-opencode/master/assets/oh-my-opencode.schema.json",
  "agents": {
    "sisyphus": {
      "model": "opencode-go/kimi-k2.5",
      "fallback_models": [
        "github-copilot/claude-opus-4.5"
      ]
    },
    "hephaestus": {
      "model": "github-copilot/gpt-5.3-codex",
      "variant": "medium"
    },
    "oracle": {
      "model": "github-copilot/gemini-3.1-pro-preview",
      "variant": "high",
      "fallback_models": [
        {
          "model": "google/gemini-3.1-pro-preview",
          "variant": "high"
        },
        {
          "model": "opencode-go/glm-5"
        }
      ]
    },
    "librarian": {
      "model": "opencode-go/minimax-m2.7"
    },
    "explore": {
      "model": "github-copilot/grok-code-fast-1",
      "fallback_models": [
        "opencode-go/minimax-m2.7-highspeed"
      ]
    },
    "multimodal-looker": {
      "model": "github-copilot/gemini-3-flash",
      "fallback_models": [
        "google/gemini-3-flash"
      ]
    },
    "prometheus": {
      "model": "opencode-go/glm-5",
      "fallback_models": [
        "github-copilot/claude-opus-4.5"
      ]
    },
    "metis": {
      "model": "opencode-go/glm-5",
      "fallback_models": [
        "github-copilot/claude-opus-4.5"
      ]
    },
    "momus": {
      "model": "github-copilot/gemini-3.1-pro-preview",
      "variant": "high",
      "fallback_models": [
        {
          "model": "google/gemini-3.1-pro-preview",
          "variant": "high"
        },
        {
          "model": "opencode-go/glm-5"
        }
      ]
    },
    "atlas": {
      "model": "opencode-go/kimi-k2.5",
      "fallback_models": [
        "github-copilot/claude-sonnet-4.5"
      ]
    },
    "sisyphus-junior": {
      "model": "github-copilot/claude-sonnet-4.6",
      "fallback_models": [
        {
          "model": "opencode-go/kimi-k2.5"
        },
        {
          "model": "github-copilot/gpt-5.4",
          "variant": "medium"
        },
        {
          "model": "opencode-go/minimax-m2.7"
        }
      ]
    }
  },
  "categories": {
    "visual-engineering": {
      "model": "google/gemini-3.1-pro-preview",
      "variant": "high",
      "fallback_models": [
        {
          "model": "github-copilot/gemini-3.1-pro-preview",
          "variant": "high"
        },
        {
          "model": "opencode-go/glm-5"
        }
      ]
    },
    "ultrabrain": {
      "model": "google/gemini-3.1-pro-preview",
      "variant": "high",
      "fallback_models": [
        {
          "model": "github-copilot/gemini-3.1-pro-preview",
          "variant": "high"
        },
        {
          "model": "opencode-go/glm-5"
        }
      ]
    },
    "deep": {
      "model": "github-copilot/gpt-5.3-codex",
      "variant": "xhigh",
      "fallback_models": [
        {
          "model": "google/gemini-3.1-pro-preview",
          "variant": "high"
        },
        {
          "model": "github-copilot/gemini-3.1-pro-preview",
          "variant": "high"
        }
      ]
    },
    "artistry": {
      "model": "google/gemini-3.1-pro-preview",
      "variant": "max",
      "fallback_models": [
        {
          "model": "github-copilot/gemini-3.1-pro-preview",
          "variant": "high"
        }
      ]
    },
    "quick": {
      "model": "github-copilot/claude-haiku-4.5",
      "fallback_models": [
        {
          "model": "google/gemini-3-flash-preview"
        },
        {
          "model": "github-copilot/gemini-3-flash-preview"
        },
        {
          "model": "opencode-go/minimax-m2.7"
        }
      ]
    },
    "unspecified-low": {
      "model": "github-copilot/gpt-5.3-codex",
      "variant": "medium",
      "fallback_models": [
        "opencode-go/kimi-k2.5",
        "github-copilot/claude-sonnet-4.5"
      ]
    },
    "unspecified-high": {
      "model": "opencode-go/glm-5",
      "fallback_models": [
        "opencode-go/glm-5"
      ],
      "variant": "max"
    },
    "writing": {
      "model": "github-copilot/gemini-3-flash",
      "fallback_models": [
        {
          "model": "opencode-go/kimi-k2.5"
        },
        {
          "model": "opencode-go/minimax-m2.7"
        }
      ]
    }
  },
  "tmux": {
    "enabled": true,
    "layout": "main-vertical",
    "main_pane_size": 60,
    "main_pane_min_width": 120,
    "agent_pane_min_width": 40
  },
  "browser_automation_engine": {
    "provider": "agent-browser"
  },
  "runtime_fallback": {
    "enabled": true
  }
}
