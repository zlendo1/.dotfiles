#!/usr/bin/env bash
#
# pman - Project Manager
# Manage projects in a centralized directory.
#

set -euo pipefail

DEFAULT_PROJECTS_DIR="$HOME/Projects"
CONFIG_FILE="$HOME/.config/pman/config.ini"

# Get the projects directory from config or default
get_projects_dir() {
    if [[ -f "$CONFIG_FILE" ]]; then
        local dir
        dir=$(grep -E '^\s*projects_dir\s*=' "$CONFIG_FILE" 2>/dev/null | head -1 | cut -d'=' -f2 | xargs)
        if [[ -n "$dir" ]]; then
            # Expand ~ to $HOME
            echo "${dir/#\~/$HOME}"
            return
        fi
    fi
    echo "$DEFAULT_PROJECTS_DIR"
}

# Ensure the projects directory exists
ensure_projects_dir() {
    local projects_dir="$1"
    local create_parent="$2"

    if [[ ! -d "$projects_dir" ]]; then
        if [[ "$create_parent" == "true" ]]; then
            mkdir -p "$projects_dir"
        else
            echo "Error: $projects_dir does not exist." >&2
            echo "Use -p or --parent to create it." >&2
            exit 1
        fi
    fi
}

# Clone a git repository into the projects directory
cmd_clone() {
    local projects_dir="$1"
    local create_parent="$2"
    local url="${3:-}"

    if [[ -z "$url" ]]; then
        echo "Error: clone requires a git URL" >&2
        echo "Usage: pman clone <git-url>" >&2
        exit 1
    fi

    ensure_projects_dir "$projects_dir" "$create_parent"
    cd "$projects_dir" && git clone "$url"
}

# Create an empty project with git init
cmd_init() {
    local projects_dir="$1"
    local create_parent="$2"
    local name="${3:-}"

    if [[ -z "$name" ]]; then
        echo "Error: init requires a project name" >&2
        echo "Usage: pman init <project-name>" >&2
        exit 1
    fi

    ensure_projects_dir "$projects_dir" "$create_parent"
    local project_path="$projects_dir/$name"

    if [[ -e "$project_path" ]]; then
        echo "Error: $project_path already exists." >&2
        exit 1
    fi

    mkdir -p "$project_path"
    git -C "$project_path" init
    echo "Initialized empty project: $project_path"
}

# Output the path to a project directory (for shell wrapper)
cmd_cd() {
    local projects_dir="$1"
    local name="${3:-}"

    if [[ -z "$name" ]]; then
        echo "Error: cd requires a project name" >&2
        echo "Usage: pman cd <project-name>" >&2
        exit 1
    fi

    local project_path="$projects_dir/$name"

    if [[ ! -d "$project_path" ]]; then
        echo "Error: Project '$name' does not exist in $projects_dir" >&2
        exit 1
    fi

    # Output the path for the shell wrapper to cd into
    echo "$project_path"
}

# Remove a project directory
cmd_rm() {
    local projects_dir="$1"
    local name="${3:-}"

    if [[ -z "$name" ]]; then
        echo "Error: rm requires a project name" >&2
        echo "Usage: pman rm <project-name>" >&2
        exit 1
    fi

    local project_path="$projects_dir/$name"

    if [[ ! -e "$project_path" ]]; then
        echo "Error: Project '$name' does not exist in $projects_dir" >&2
        exit 1
    fi

    echo "About to remove: $project_path"
    read -rp "Are you sure? [y/N] " response
    response="${response,,}"  # lowercase

    if [[ "$response" == "y" ]]; then
        rm -rf "$project_path"
        echo "Removed: $project_path"
    else
        echo "Cancelled."
    fi
}

# List all projects
cmd_ls() {
    local projects_dir="$1"

    if [[ -d "$projects_dir" ]]; then
        for item in "$projects_dir"/*; do
            if [[ -d "$item" ]]; then
                basename "$item"
            fi
        done | sort
    fi
}

# Output zsh shell integration (wrapper function, completions, fzf-tab preview)
cmd_zsh_integration() {
    cat <<'EOZSH'
# pman - Project Manager shell integration
# Generated by: pman --zsh
# Add to .zshrc: eval "$(pman --zsh)"

# Helper to get projects directory from config
_pman_projects_dir() {
  local dir="$HOME/Projects"
  local config="$HOME/.config/pman/config.ini"
  if [[ -f "$config" ]]; then
    local parsed
    parsed=$(grep -E '^\s*projects_dir\s*=' "$config" 2>/dev/null | sed 's/.*=\s*//' | sed 's/~/$HOME/g')
    if [[ -n "$parsed" ]]; then
      dir=$(eval echo "$parsed")
    fi
  fi
  echo "$dir"
}

# Wrapper function to handle 'cd' command (scripts can't change parent shell directory)
pman() {
  if [[ "$1" == "cd" ]]; then
    local target
    target=$(command pman cd "$2" 2>&1)
    if [[ $? -eq 0 && -d "$target" ]]; then
      cd "$target"
    else
      echo "$target"
      return 1
    fi
  else
    command pman "$@"
  fi
}

# Completion function
_pman() {
  local -a commands
  local projects_dir="$(_pman_projects_dir)"
  commands=(
    'clone:Clone a git repository'
    'init:Create an empty project with git init'
    'cd:Navigate to a project directory'
    'rm:Remove a project directory'
    'ls:List all projects'
  )
  
  if (( CURRENT == 2 )); then
    _describe -t commands 'pman commands' commands
  elif (( CURRENT == 3 )); then
    case "${words[2]}" in
      cd|rm)
        local -a projects
        if [[ -d "$projects_dir" ]]; then
          projects=(${(f)"$(ls -1 "$projects_dir" 2>/dev/null)"})
          _describe -t projects 'projects' projects
        fi
        ;;
    esac
  fi
}

# Register completion
compdef _pman pman

# fzf-tab preview for pman cd/rm
zstyle ':fzf-tab:complete:pman:*' fzf-preview 'ls --color "$(_pman_projects_dir)/$word" 2>/dev/null || echo "No preview"'
EOZSH
}

# Print usage/help
usage() {
    local projects_dir
    projects_dir=$(get_projects_dir)

    cat <<EOF
pman - Project Manager

Usage: pman [OPTIONS] COMMAND [ARGS]

Options:
  -p, --parent    Create projects directory if it does not exist
  -h, --help      Show this help message
  --zsh           Output zsh shell integration (for eval in .zshrc)

Commands:
  clone <url>     Clone a git repository
  init <name>     Create an empty project with git init
  cd <name>       Navigate to a project directory
  rm <name>       Remove a project directory
  ls, list        List all projects

Manage projects in $projects_dir

Configuration:
  ~/.config/pman/config.ini    INI file to override default ~/Projects

  Example config.ini:
    [pman]
    projects_dir = ~/Projects

Examples:
  pman clone https://github.com/user/repo.git
  pman init my-new-project
  pman cd my-project
  pman rm old-project
  pman ls
EOF
}

main() {
    local create_parent="false"
    local command=""
    local args=()

    # Parse options
    while [[ $# -gt 0 ]]; do
        case "$1" in
            -p|--parent)
                create_parent="true"
                shift
                ;;
            -h|--help)
                usage
                exit 0
                ;;
            --zsh)
                cmd_zsh_integration
                exit 0
                ;;
            -*)
                echo "Unknown option: $1" >&2
                exit 1
                ;;
            *)
                if [[ -z "$command" ]]; then
                    command="$1"
                else
                    args+=("$1")
                fi
                shift
                ;;
        esac
    done

    if [[ -z "$command" ]]; then
        usage
        exit 1
    fi

    local projects_dir
    projects_dir=$(get_projects_dir)

    case "$command" in
        clone)
            cmd_clone "$projects_dir" "$create_parent" "${args[0]:-}"
            ;;
        init)
            cmd_init "$projects_dir" "$create_parent" "${args[0]:-}"
            ;;
        cd)
            cmd_cd "$projects_dir" "$create_parent" "${args[0]:-}"
            ;;
        rm)
            cmd_rm "$projects_dir" "$create_parent" "${args[0]:-}"
            ;;
        ls|list)
            cmd_ls "$projects_dir"
            ;;
        *)
            echo "Unknown command: $command" >&2
            usage
            exit 1
            ;;
    esac
}

main "$@"
